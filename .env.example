# ============================================================
# medagent-core — Environment Configuration Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
KIMI_API_KEY=...

# --- LLM Model Overrides (optional) ---
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-1.5-pro
KIMI_MODEL=moonshot-v1-32k

# --- PubMed / NCBI ---
# Register at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# --- OpenFDA ---
# Register at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/audit.db
# For production Postgres:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/medagent

# --- Agent Behaviour ---
# Minimum confidence before ESCALATE is triggered (0.0 – 1.0)
AGENT_CONFIDENCE_THRESHOLD=0.6
# Hard wall-clock cap per agent run in seconds
AGENT_TOTAL_TIMEOUT_SECONDS=120
AGENT_ENTITY_EXTRACTION_TIMEOUT=10
AGENT_RETRIEVAL_TIMEOUT=20
AGENT_REASONING_TIMEOUT=90

# --- Knowledge Base ---
# Path to UMLS/BioWordVec embedding file (optional local KB)
KB_EMBEDDING_PATH=./data/biowordvec_pubmed_mesh_200d.bin
KB_INDEX_PATH=./data/kb_index/

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO

# --- Security ---
# Salt for PII hashing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_HASH_SALT=change-me-to-a-random-hex-string

# --- Evaluation ---
MEDQA_DATA_PATH=./data/medqa_usmle_4_options_test.jsonl
DRUGBANK_TEST_PATH=./data/drugbank_interactions_test.json
EVAL_MAX_SAMPLES=100
